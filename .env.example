# Copy to .env (gitignored) and fill in your values.
# Run: node --env-file=.env scripts/feed-mqtt-sondehub.mjs [serial]

# Sensor API bearer token (Settings -> Sensor API)
SONDE_TOKEN=your-sensor-api-bearer-token

# Your ground station -- used only to compute DIST. Optional:
# if omitted, DIST is measured from the first frame observed.
HOME_LAT=
HOME_LON=

# Optional overrides
# SONDE_SERIAL=Y0322354
# SONDE_URL=http://127.0.0.1:1337
# SONDE_BROKER=wss://ws-reader.v2.sondehub.org/
